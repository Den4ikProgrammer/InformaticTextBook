<Page x:Class="InformaticTextBook.Pages.SearchResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InformaticTextBook.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SearchResultPage">

    <DockPanel Background="#FFFDD0">
        <!-- Верхняя панель -->
        <Grid DockPanel.Dock="Top" Height="40" Background="#556B2F">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Content="Назад" Margin="5" Padding="10,2" 
                    VerticalAlignment="Center" Click="BackButton_Click"/>
            <TextBlock Text="{Binding TitleText}" Grid.Column="1" HorizontalAlignment="Center"
                       Foreground="#FFFDD0" FontWeight="Bold" FontSize="16"/>
            <TextBlock Text="{Binding UserLoginText}" Grid.Column="2" 
                       VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#FFFDD0"/>
        </Grid>

        <Grid Margin="15">
            <!-- Если нет результатов -->
            <TextBlock x:Name="NoResultsText" 
                       Text="По вашему запросу ничего не найдено" 
                       FontSize="16" Foreground="#CD853F" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <!-- Список результатов -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ResultsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F5DEB3" CornerRadius="8" 
                                    Padding="15" Margin="0 0 0 10" Cursor="Hand"
                                    MouseLeftButtonDown="Result_Click">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📚" FontSize="14" Margin="0 0 5 0"/>
                                        <TextBlock Text="{Binding ThemeName}" 
                                                   FontWeight="Bold" Foreground="#CD853F" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding LectionName}" 
                                               FontWeight="Bold" FontSize="16" 
                                               Foreground="#556B2F" Margin="0 5"/>
                                    <TextBlock Text="{Binding Snippet}" 
                                               TextWrapping="Wrap" FontSize="13" 
                                               Foreground="#556B2F"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Page>
