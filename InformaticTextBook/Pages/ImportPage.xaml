<Page x:Class="InformaticTextBook.Pages.ImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:InformaticTextBook.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Импорт данных" Loaded="Page_Loaded">

    <DockPanel Background="#FFFDD0">

        <!-- Верхняя панель -->
        <Grid DockPanel.Dock="Top" Height="40" Background="#556B2F">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Назад" Margin="5" Padding="10,2"
                    VerticalAlignment="Center" Click="BackButton_Click"/>

            <TextBlock Text="Импорт лекций" Grid.Column="1" VerticalAlignment="Center"
                       HorizontalAlignment="Center" Foreground="#FFFDD0" 
                       FontWeight="Bold" FontSize="16"/>

            <TextBlock Text="{Binding UserLoginText}" Grid.Column="2"
                       VerticalAlignment="Center" Margin="0,0,10,0"
                       Foreground="#FFFDD0" FontWeight="SemiBold"/>
        </Grid>

        <!-- Основное содержимое -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15">
            <StackPanel>

                <!-- Краткая инструкция -->
                <Border BorderBrush="#556B2F" BorderThickness="2"
                        CornerRadius="10" Padding="15" Background="#F5DEB3" Margin="0 0 0 15">
                    <StackPanel>
                        <TextBlock Text="Импорт из Word (DOCX)" FontSize="20" FontWeight="Bold"
                                   Foreground="#556B2F" Margin="0 0 0 10"/>

                        <TextBlock Text="Требования к оформлению документа:" 
                                   FontWeight="SemiBold" Margin="0 5"/>

                        <TextBlock Text="• Заголовок 1 — название темы" Margin="10 2"/>
                        <TextBlock Text="• Заголовок 2 — название лекции" Margin="10 2"/>
                        <TextBlock Text="• Обычный текст — содержание лекции" Margin="10 2"/>
                        <TextBlock Text="• Жирный и курсив преобразуются в Markdown" Margin="10 2"/>
                        <TextBlock Text="• Вопросы: 1. ... a) ... b) ... c) ... d) ..." Margin="10 2"/>
                        <TextBlock Text="• Правильный ответ помечайте (*)" Margin="10 2"/>

                        <Button x:Name="DownloadTemplateButton" 
                                Content="📥 Скачать шаблон DOCX" 
                                Margin="0 10 0 0" Padding="15 5"
                                Background="#CD853F" Foreground="#FFFDD0"
                                Click="DownloadTemplateButton_Click"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Выбор файла -->
                <Border BorderBrush="#556B2F" BorderThickness="2"
                        CornerRadius="10" Padding="15" Background="#F5DEB3" Margin="0 0 0 15">
                    <StackPanel>
                        <TextBlock Text="Выберите DOCX-файл" FontSize="18" FontWeight="Bold"
                                   Foreground="#556B2F" Margin="0 0 0 10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FilePathTextBox" Grid.Column="0" 
                                     Margin="0 0 10 0" IsReadOnly="True"
                                     Background="#FFFDD0"/>

                            <Button x:Name="BrowseButton" Grid.Column="1" 
                                    Content="Обзор..." Padding="15 5"
                                    Click="BrowseButton_Click"/>
                        </Grid>

                        <TextBlock x:Name="FileInfoText" Margin="0 10 0 0"
                                   TextWrapping="Wrap" Foreground="#CD853F"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки управления -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 15">
                    <Button x:Name="ImportButton" Content="Начать импорт" 
                            Padding="20 10" FontSize="16" FontWeight="Bold"
                            Background="#CD853F" Foreground="#FFFDD0"
                            Click="ImportButton_Click" IsEnabled="False"/>

                    <Button x:Name="ClearButton" Content="Очистить" 
                            Padding="20 10" FontSize="16" Margin="15 0 0 0"
                            Click="ClearButton_Click"/>
                </StackPanel>

                <!-- Результаты импорта -->
                <Border x:Name="ResultBorder" BorderBrush="#556B2F" BorderThickness="2"
                        CornerRadius="10" Padding="15" Background="#F5DEB3" 
                        Margin="0 15 0 0" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="ResultTitle" Text="Результаты импорта" 
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#556B2F" Margin="0 0 0 10"/>

                        <TextBlock x:Name="ResultText" TextWrapping="Wrap" 
                                   FontSize="14" Foreground="#556B2F"/>

                        <ItemsControl x:Name="ErrorList" Margin="0 10 0 0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#CD5C5C" 
                                               Margin="0 2" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Page>