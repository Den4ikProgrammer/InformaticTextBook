<Page x:Class="InformaticTextBook.Pages.StudentsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InformaticTextBook.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Список студентов" Loaded="Page_Loaded">

    <DockPanel Background="#FFFDD0">
        <Grid DockPanel.Dock="Top" Height="40" Background="#556B2F">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

           
            <Button Content="Назад" Margin="5" Padding="10,2"
                    VerticalAlignment="Center" Click="BackButton_Click"/>
            <Button x:Name="ExportButton" Content="Экспорт в Excel" Margin="5" Padding="10,2"
                    VerticalAlignment="Center" HorizontalAlignment="Right" Click="ExportButton_Click" Grid.Column="4"/>

            <TextBlock Text="Список студентов" VerticalAlignment="Center"
                       HorizontalAlignment="Center" Foreground="#FFFDD0" FontWeight="Bold" Grid.Column="1"/>

            <TextBlock Text="{Binding UserLoginText}" Grid.Column="2"
                       VerticalAlignment="Center" Margin="0,0,10,0"
                       Foreground="#FFFDD0" FontWeight="SemiBold"/>
        </Grid>
        
        <!-- Поиск -->
        <Border DockPanel.Dock="Top" Background="#F5DEB3" Padding="10" Margin="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Поиск:" VerticalAlignment="Center" 
                           Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox x:Name="SearchTextBox" Width="250" 
                         TextChanged="SearchTextBox_TextChanged"
                         Background="#FFFDD0" BorderBrush="#556B2F"/>

                <Button x:Name="RefreshButton" Content="Обновить" Margin="20,0,0,0"
                        Padding="10,5" Click="RefreshButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Список студентов -->
            <Border Grid.Column="0" Background="#F5DEB3" Margin="5">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Студенты:" 
                               Margin="10,10,10,5" FontWeight="Bold" FontSize="16"/>

                    <ListBox x:Name="StudentsListBox" 
                             ItemsSource="{Binding Students}"
                             SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                             Background="#FFFDD0" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="15,10" Margin="2" 
                                        Background="{Binding BackgroundColor}" 
                                        CornerRadius="5" HorizontalAlignment="Stretch"
                                        BorderBrush="#CD853F" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Информация о студенте -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding UserLogin}" 
                                                       FontWeight="Bold" FontSize="16"
                                                       Foreground="#556B2F"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <TextBlock Text="Лекций: " FontSize="12"/>
                                                <TextBlock Text="{Binding LectionsCount}" 
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="#556B2F" Margin="0,0,10,0"/>

                                                <TextBlock Text="Тестов: " FontSize="12"/>
                                                <TextBlock Text="{Binding TestsCount}" 
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="#556B2F" Margin="0,0,10,0"/>

                                                <TextBlock Text="Балл: " FontSize="12"/>
                                                <TextBlock Text="{Binding AverageGrade, StringFormat={}{0:F1}}" 
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="#556B2F"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Иконка выбора -->
                                        <TextBlock Grid.Column="1" Text="➔" 
                                                   FontSize="20" VerticalAlignment="Center"
                                                   Foreground="#CD853F"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#556B2F"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFF8DC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#CD853F"/>

            <!-- Детальная информация о студенте -->
            <Border Grid.Column="2" Background="#F5DEB3" Margin="5" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Информация о студенте" 
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#556B2F" Margin="0,0,0,15"/>

                        <!-- Плейсхолдер при выборе студента -->
                        <Border x:Name="NoSelectionBorder" 
                                Background="#FFFDD0" CornerRadius="10" 
                                Padding="40" Visibility="Visible">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="👨‍🎓" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="Выберите студента из списка" 
                                           FontSize="18" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Margin="0,15,0,0"
                                           Foreground="#556B2F"/>
                                <TextBlock Text="Для просмотра подробной информации" 
                                           FontSize="14" HorizontalAlignment="Center"
                                           Margin="0,5,0,0" Foreground="#CD853F"/>
                            </StackPanel>
                        </Border>

                        <!-- Детальная информация -->
                        <Border x:Name="StudentDetailBorder" 
                                Background="#FFFDD0" CornerRadius="10" 
                                Padding="25" Visibility="Collapsed">
                            <StackPanel>
                                <!-- Заголовок -->
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="{Binding SelectedStudent.UserLogin}" 
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="#556B2F"/>
                                    <TextBlock Text="Студент" FontSize="16" 
                                               Foreground="#CD853F" FontStyle="Italic"/>
                                </StackPanel>

                                <!-- Статистика -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Лекции -->
                                    <Border Grid.Row="0" Grid.Column="0" 
                                            Background="#F5DEB3" CornerRadius="8"
                                            Padding="15" Margin="0,0,10,10"
                                            BorderBrush="#CD853F" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="📚" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Прочитано лекций" 
                                                       FontSize="14" Foreground="#556B2F"
                                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding SelectedStudent.LectionsCount}" 
                                                       FontSize="28" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#556B2F"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Тесты -->
                                    <Border Grid.Row="0" Grid.Column="1" 
                                            Background="#F5DEB3" CornerRadius="8"
                                            Padding="15" Margin="10,0,0,10"
                                            BorderBrush="#CD853F" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="📝" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Пройдено тестов" 
                                                       FontSize="14" Foreground="#556B2F"
                                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding SelectedStudent.TestsCount}" 
                                                       FontSize="28" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#556B2F"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Средний балл -->
                                    <Border Grid.Row="1" Grid.Column="0" 
                                            Background="#F5DEB3" CornerRadius="8"
                                            Padding="15" Margin="0,10,10,0"
                                            BorderBrush="#CD853F" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="⭐" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Средний балл" 
                                                       FontSize="14" Foreground="#556B2F"
                                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding SelectedStudent.AverageGrade, StringFormat={}{0:F1}}" 
                                                       FontSize="28" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#556B2F"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Общее время -->
                                    <Border Grid.Row="1" Grid.Column="1" 
                                            Background="#F5DEB3" CornerRadius="8"
                                            Padding="15" Margin="10,10,0,0"
                                            BorderBrush="#CD853F" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="⏱️" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Общее время" 
                                                       FontSize="14" Foreground="#556B2F"
                                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding SelectedStudent.TotalTime}" 
                                                       FontSize="20" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#556B2F"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Кнопки действий -->
                                <Button x:Name="OpenProfileButton" Margin="0,15,0,0" Content="Открыть профиль" 
                                        Padding="20,10" FontWeight="Bold" FontSize="14"
                                        Background="#CD853F" Foreground="#FFFDD0"
                                        BorderBrush="#556B2F" BorderThickness="1"
                                        Click="OpenProfileButton_Click"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Статус бар -->
        <StatusBar DockPanel.Dock="Bottom" Background="#F5DEB3" Height="25">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Всего студентов: 0"/>
            </StatusBarItem>
        </StatusBar>

        <!--<ListBox x:Name="StudentsListBox" Margin="15" Background="#F5DEB3"
                 ItemsSource="{Binding Students}" MouseDoubleClick="Student_DoubleClick" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15,10" Margin="2" Background="#FFFDD0" CornerRadius="5" HorizontalAlignment="Stretch">
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="👤" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,15,0">
                                <TextBlock Text="{Binding Role.RoleName}" FontStyle="Italic" FontSize="16" Foreground="#556B2F" Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding UserLogin}" FontWeight="Bold" FontSize="20"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="➔" Foreground="#CD853F" FontSize="20" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>-->
    </DockPanel>
</Page>
