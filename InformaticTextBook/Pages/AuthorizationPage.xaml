<Page x:Class="InformaticTextBook.Pages.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InformaticTextBook.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="1000"
      Title="Авторизация">

    <Grid Background="#F5DEB3">
        <!-- Кремовый фон, как в основном окне -->
        <StackPanel  VerticalAlignment="Center" HorizontalAlignment="Center">
            <Viewbox Height="700">
                <StackPanel>
                    <Ellipse Width="100" Height="100" Margin="0,20,0,0">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/logo.png"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel Orientation="Horizontal" Margin="0,50,0,10" HorizontalAlignment="Center">
                        <Label Content="Логин:" Width="65" Foreground="#556B2F" FontWeight="SemiBold"/>
                        <TextBox x:Name="authorizationLoginTextBox" Width="250" 
                 TextChanged="AuthorizationLoginTextBox_TextChanged"
                 Background="#FFFDD0" BorderBrush="#556B2F" Foreground="#556B2F" FontFamily="Comic Sans MS" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,15" HorizontalAlignment="Center">
                        <Label Content="Пароль:" Width="65" Foreground="#556B2F" FontWeight="SemiBold"/>
                        <PasswordBox x:Name="authorizationPasswordTextBox" Width="250" 
                     PasswordChanged="AuthorizationPasswordTextBox_PasswordChanged"
                     Background="#FFFDD0" BorderBrush="#556B2F" Foreground="#556B2F" FontFamily="Comic Sans MS" FontSize="15"/>
                    </StackPanel>

                    <Label x:Name="IncorrectDataLabel" Content="*Логин или Пароль введены неверно" Foreground="#CD5C5C" 
               Visibility="Hidden" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5,0,0"/>
                    <Button x:Name="authorizeButton" Content="Авторизоваться" Margin="10" Padding="10,5" Width="180"
            HorizontalAlignment="Center" Click="AuthorizeButton_Click"
            Background="#CD853F" BorderBrush="#556B2F" Foreground="#FFFDD0" FontFamily="Comic Sans MS" FontSize="15"/>

                </StackPanel>
            </Viewbox>
        </StackPanel>
    </Grid>
</Page>
