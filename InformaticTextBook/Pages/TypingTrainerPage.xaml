<Page x:Class="InformaticTextBook.Pages.TypingTrainerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InformaticTextBook.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Тренажёр печати" Loaded="Page_Loaded">
    <DockPanel Background="#FFFDD0">
        <Grid DockPanel.Dock="Top" Height="40" Background="#556B2F">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Content="Назад" Margin="5" Padding="10,2" Click="BackButton_Click"/>
            <TextBlock Text="Тренажёр скорости печати" Grid.Column="1" HorizontalAlignment="Center"
                       Foreground="#FFFDD0" FontWeight="Bold" FontSize="16"/>
            <TextBlock Text="{Binding UserLoginText}" Grid.Column="2" Margin="0,0,10,0" Foreground="#FFFDD0"/>
        </Grid>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: тренажёр -->
            <Grid Grid.Column="0" Margin="0 0 10 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Выбор сложности -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 10" Background="#F5DEB3">
                    <TextBlock Text="Сложность:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 10 0"/>
                    <ComboBox x:Name="DifficultyComboBox" Width="150" SelectedIndex="1">
                        <ComboBoxItem Content="Лёгкий" Tag="Easy"/>
                        <ComboBoxItem Content="Средний" Tag="Normal"/>
                        <ComboBoxItem Content="Сложный" Tag="Hard"/>
                    </ComboBox>
                    <Button Content="Новый текст" Margin="10 0 0 0" Padding="10 2" Click="NewTextButton_Click"/>
                </StackPanel>

                <!-- Статистика -->
                <Border Grid.Row="1" Background="#F5DEB3" CornerRadius="8" Padding="10" Margin="0 0 0 10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Скорость: " FontWeight="Bold"/>
                        <TextBlock Text="{Binding Speed, StringFormat={}{0:F1} зн/мин}" Margin="0 0 20 0"/>
                        <TextBlock Text="Точность: " FontWeight="Bold"/>
                        <TextBlock Text="{Binding Accuracy, StringFormat={}{0:F1}%}" Margin="0 0 20 0"/>
                        <TextBlock Text="Время: " FontWeight="Bold"/>
                        <TextBlock Text="{Binding ElapsedTimeText}"/>
                    </StackPanel>
                </Border>

                <!-- Эталонный текст -->
                <Border Grid.Row="2" Background="#EED9B7" CornerRadius="8" Padding="15" Margin="0 0 0 10">
                    <TextBlock Text="{Binding TargetText}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14"/>
                </Border>

                <!-- Поле ввода с подсветкой -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0 0 0 10">
                    <Border Background="White" CornerRadius="8" Padding="5"
                                BorderBrush="#556B2F" BorderThickness="1">
                        <Grid>
                            <!-- Подсвеченный текст (как подложка) -->
                            <TextBlock x:Name="HighlightedTextBlock" 
                               FontFamily="Consolas" FontSize="14" 
                               Background="White" TextWrapping="Wrap"
                               Padding="4,4,4,4"
                               VerticalAlignment="Top"/>
                            <!-- Прозрачное поле ввода поверх -->
                            <TextBox x:Name="InputTextBox" 
                             Background="Transparent" 
                             FontFamily="Consolas" FontSize="14"
                             Foreground="Transparent" 
                             CaretBrush="Black" 
                             TextChanged="InputTextBox_TextChanged"
                             IsEnabled="{Binding IsTyping}" 
                             MaxLength="2000" 
                             BorderThickness="0"
                             TextWrapping="Wrap" 
                             AcceptsReturn="False"
                             Padding="4,4,4,4"
                             VerticalContentAlignment="Top"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Top"/>          
                        </Grid>
                    </Border>
                </ScrollViewer>

                <!-- Кнопки -->
                <StackPanel Grid.Row="4" HorizontalAlignment="Center" Margin="0 10">
                    <Button x:Name="StartButton" Content="Начать тренировку" Padding="20 10"
                            Background="#CD853F" Foreground="#FFFDD0" Click="StartButton_Click"/>
                    <Button x:Name="FinishButton" Content="Завершить" Padding="20 10" Margin="10 0 0 0"
                            Visibility="Collapsed" Click="FinishButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Правая панель: рекорд + история -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                

                <!-- Лучший результат -->
                <Border Grid.Row="0" Background="#F5DEB3" CornerRadius="8" Padding="15" Margin="0 0 0 10">
                    <StackPanel>
                        <TextBlock Text="🏆 Лучший результат" FontWeight="Bold" FontSize="16" Foreground="#556B2F"/>
                        <TextBlock x:Name="BestResultText" Text="Нет данных" Margin="0 5 0 0" TextWrapping="Wrap" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- История -->
                <Border Grid.Row="1" Background="#F5DEB3" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📋 Последние попытки" FontWeight="Bold" FontSize="16" Foreground="#556B2F" Margin="0 0 10 0"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HistoryItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="5" Margin="0 2" Background="#FFFDD0" CornerRadius="4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DateRecorded, StringFormat={}{0:dd.MM.yyyy HH:mm }}" FontSize="11" Foreground="#556B2F">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Speed, StringFormat={}{0:F0} зн/мин}" 
                                                                       FontWeight="Bold" Margin="0 0 10 0" FontSize="12"/>
                                                        <TextBlock Text="{Binding Accuracy, StringFormat={}{0:F1}%}" FontSize="12"/>
                                                    </StackPanel>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Page>
