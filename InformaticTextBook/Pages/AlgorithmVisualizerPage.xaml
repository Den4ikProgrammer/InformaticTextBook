<Page x:Class="InformaticTextBook.Pages.AlgorithmVisualizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InformaticTextBook.Pages"
      xmlns:converters="clr-namespace:InformaticTextBook.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Визуализатор алгоритмов" Loaded="Page_Loaded">

    <DockPanel Background="#FFFDD0">
        <!-- Верхняя панель навигации -->
        <Grid DockPanel.Dock="Top" Height="40" Background="#556B2F">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Content="Назад" Margin="5" Padding="10,2" Click="BackButton_Click"/>
            <TextBlock Text="Визуализатор алгоритмов" Grid.Column="1" HorizontalAlignment="Center"
                       Foreground="#FFFDD0" FontWeight="Bold" FontSize="16"/>
            <TextBlock Text="{Binding UserLoginText}" Grid.Column="2" Margin="0,0,10,0" Foreground="#FFFDD0"/>
        </Grid>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Выбор алгоритма и данных -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 10" Background="#F5DEB3">
                <TextBlock Text="Алгоритм:" VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox x:Name="AlgoComboBox" Width="200" Margin="5" SelectedIndex="0"
                          SelectionChanged="AlgoComboBox_SelectionChanged">
                    <ComboBoxItem Content="Пузырьковая сортировка" Tag="BubbleSort"/>
                    <ComboBoxItem Content="Сортировка вставками" Tag="InsertionSort"/>
                    <ComboBoxItem Content="Линейный поиск" Tag="LinearSearch"/>
                    <!--<ComboBoxItem Content="Бинарный поиск" Tag="BinarySearch"/>-->
                </ComboBox>
                <TextBlock Text="Данные (через запятую):" VerticalAlignment="Center" Margin="10 0 5 0"/>
                <TextBox x:Name="DataTextBox" Width="200" Text="8,3,6,1,9,2,5,4,7"/>
                <TextBlock Text="Искомое число:" VerticalAlignment="Center" Margin="10 0 5 0" 
                          x:Name="TargetLabel" Visibility="Collapsed"/>
                <TextBox x:Name="TargetTextBox" Width="50" Text="5" 
                          Visibility="Collapsed" Margin="0 0 5 0"/>
                <Button Content="Загрузить" Margin="5" Padding="10 2" Click="LoadDataButton_Click"/>
            </StackPanel>

            <!-- Панель управления -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10">
                <Button x:Name="PlayButton" Content="▶ Начать" Padding="15 5" Background="#CD853F" Foreground="#FFFDD0"
                        Click="PlayButton_Click"/>
                <!--<Button x:Name="PauseButton" Content="⏸ Пауза" Padding="15 5" Margin="5 0" IsEnabled="False"
                        Click="PauseButton_Click"/>-->
                <Button x:Name="StepBackButton" Content="⏮ Шаг назад" Padding="15 5" Margin="5 0"
                        Click="StepBackButton_Click"/>
                <Button x:Name="StepForwardButton" Content="⏭ Шаг вперёд" Padding="15 5" Margin="5 0"
                        Click="StepForwardButton_Click"/>
                <Button x:Name="ResetButton" Content="↺ Сброс" Padding="15 5" Margin="5 0"
                        Click="ResetButton_Click"/>
            </StackPanel>

            <!-- Скорость и слайдер -->
            <!--<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5">
                <TextBlock Text="Скорость:" VerticalAlignment="Center"/>
                <Slider x:Name="SpeedSlider" Width="150" Minimum="0.2" Maximum="2" Value="0.6" 
                        TickFrequency="0.2" IsSnapToTickEnabled="True" Margin="5"/>
                <TextBlock Text="{Binding ElementName=SpeedSlider, Path=Value, StringFormat={}{0:F1} с}" VerticalAlignment="Center"/>
            </StackPanel>-->

            <!-- Область отображения: псевдокод + визуализация -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Псевдокод -->
                <Border Grid.Column="0" Background="#F5DEB3" CornerRadius="5" Padding="10" Margin="0 0 10 0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Псевдокод" FontWeight="Bold" Margin="0 0 0 5"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="PseudoCodeItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="PseudoLineBorder" Padding="2">
                                            <TextBlock Text="{Binding Text}" FontFamily="Consolas" FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Холст с элементами (столбики/ячейки) -->
                <Canvas x:Name="VisualCanvas" Grid.Column="1" Background="White" ClipToBounds="True">
                    <!-- Элементы добавляются программно -->
                </Canvas>
            </Grid>

            <!-- Статус -->
            <StatusBar Grid.Row="4" Background="#F5DEB3" Margin="0 5 0 0">
                <StatusBarItem>
                    <TextBlock x:Name="StatusText" Text="Готово"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </DockPanel>
</Page>
